---
import { Typewriter } from './Typewriter';
---

<section class="relative z-20 px-4 py-8 md:p-8">
  <div class="text-center">
    <h1
      class="font-heading mb-8 text-3xl leading-tight font-black uppercase md:text-4xl lg:text-5xl xl:text-6xl"
    >
      Nuclear is a
      <span
        class="font-heading"
        style="color: var(--color-heading-accent); text-shadow: 2px 2px 0px var(--color-heading-shadow);"
        >music player</span
      ><br />
      <Typewriter client:load />
    </h1>
    <span class="absolute z-20 flex">
      <img class="relative w-30" src="images/new-nuki-hello.png" />
    </span>
  </div>
</section>

<style>
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>
