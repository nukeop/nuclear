---
import { versionTag } from '../data/version';
import { Typewriter } from './Typewriter';
---

<section class="px-4 py-8 md:p-8 z-10 relative">
  <div class="text-center">
    <div
      class="inline-block mb-6 themed-border border-border bg-[var(--color-badge)] rounded-md px-4 py-1 text-sm font-bold uppercase tracking-widest shadow-shadow"
    >
      {versionTag} Available Now
    </div>

    <h1
      class="font-heading mb-8 text-3xl font-black uppercase leading-tight md:text-4xl lg:text-5xl xl:text-6xl"
    >
      Nuclear is a
      <span
        class="font-heading"
        style="color: var(--color-heading-accent); text-shadow: 2px 2px 0px var(--color-heading-shadow);"
        >music player</span
      ><br />
      <Typewriter client:load />
    </h1>
  </div>
</section>

<style>
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>
