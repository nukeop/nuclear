---
import { versionTag } from '../data/version';
---

<section class="px-4 py-8 md:p-8 z-10 relative">
  <div class="text-center">
    <div
      class="inline-block mb-6 themed-border border-border bg-[var(--color-badge)] rounded-md px-4 py-1 text-sm font-bold uppercase tracking-widest shadow-shadow"
    >
      {versionTag} Available Now
    </div>

    <h1
      class="font-heading mb-8 text-5xl font-black uppercase leading-none md:text-6xl lg:text-7xl xl:text-8xl"
    >
      A GODDAMN<br />
      <span
        class="font-heading"
        style="color: var(--color-heading-accent); text-shadow: 2px 2px 0px var(--color-heading-shadow);"
        >MUSIC PLAYER</span
      >
    </h1>

    <p
      class="mb-8 xl:text-2xl md:text-xl font-medium text-foreground-secondary max-w-xl mx-auto"
    >
      Nuclear was built with one purpose: to let you listen to music however you
      want.
    </p>
  </div>
</section>
