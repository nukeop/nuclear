---
import { Icon } from 'astro-icon/components';

const platforms = [
  {
    name: 'macOS',
    icon: 'simple-icons:apple',
    url: 'https://github.com/nukeop/nuclear/releases/download/player@1.11.1/nuclear-music-player_1.11.1_aarch64.dmg',
  },
  {
    name: 'Windows',
    icon: 'simple-icons:windows',
    url: 'https://github.com/nukeop/nuclear/releases/download/player@1.11.1/nuclear-music-player_1.11.1_x64-setup.exe',
  },
  {
    name: 'Linux',
    icon: 'simple-icons:linux',
    url: 'https://github.com/nukeop/nuclear/releases/download/player@1.11.1/nuclear-music-player_1.11.1_amd64.AppImage',
  },
];
---

<div class="border-2 border-border bg-primary rounded-md shadow-shadow px-6 py-5 relative z-10 text-center md:hidden">
  <h2 class="absolute -top-4 left-1/2 -translate-x-1/2 border-2 border-border bg-[#FFD6E0] rounded-md px-4 py-1 font-heading text-sm font-black uppercase tracking-widest whitespace-nowrap">
    Desktop only
  </h2>
  <div class="flex justify-center gap-3 mt-1 pointer-events-none select-none">
    {platforms.map((platform) => (
      <span class="inline-flex items-center gap-2 border-2 border-border/40 bg-white/40 text-foreground/40 rounded-md px-4 py-2 text-sm font-bold">
        <Icon name={platform.icon} class="w-4 h-4" />
        {platform.name}
      </span>
    ))}
  </div>
  <p class="text-xs mt-3">
    Downloads are only available on a desktop device.
  </p>
</div>

<section
  id="downloads"
  class="hidden md:block border-2 border-border bg-primary rounded-md shadow-shadow px-8 py-6 relative z-10"
>
  <h2
    class="absolute -top-4 left-1/2 -translate-x-1/2 border-2 border-border bg-[#FFD6E0] rounded-md px-4 py-1 font-heading text-sm font-black uppercase tracking-widest whitespace-nowrap"
  >
    Downloads
  </h2>
  <div class="flex justify-center gap-4 mt-2">
    {
      platforms.map((platform) => (
        <a
          href={platform.url}
          class="inline-flex items-center gap-2.5 border-2 border-border bg-white rounded-md px-6 py-3 font-bold shadow-shadow transition-all hover:translate-x-shadow-x hover:translate-y-shadow-y hover:shadow-none"
        >
          <Icon name={platform.icon} class="w-5 h-5" />
          {platform.name}
        </a>
      ))
    }
  </div>
  <a
    href="https://github.com/nukeop/nuclear/releases"
    class="block text-center text-sm font-medium mt-4 underline underline-offset-2 hover:no-underline"
  >
    All downloads
  </a>
</section>

<a
  href="https://github.com/nukeop/nuclear"
  class="hidden md:inline-flex items-center gap-2.5 border-2 border-border bg-white rounded-md px-6 py-3 font-bold shadow-shadow transition-all hover:translate-x-shadow-x hover:translate-y-shadow-y hover:shadow-none mt-6 relative z-10"
>
  <Icon name="simple-icons:github" class="w-5 h-5" />
  Learn more
</a>
