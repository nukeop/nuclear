---
import clsx from 'clsx';

const proseClasses = clsx(
  'prose prose-neutral dark:prose-invert max-w-none cursor-auto select-text',
  'prose-headings:font-heading prose-headings:font-black prose-headings:tracking-wide',
  'prose-a:text-primary prose-a:font-bold',
);
---

<div class={proseClasses}>
  <slot />
</div>
