---
import { avatarUrl, formatDate } from '../data/blog';

type Props = {
  author: string;
  date: Date;
  readTime?: number;
  class?: string;
};

const { author, date, readTime, class: className } = Astro.props;
---

<div class:list={['flex items-center gap-3', className]}>
  <img
    src={avatarUrl(author)}
    alt={author}
    loading="lazy"
    width="36"
    height="36"
    class="themed-border border-border h-9 w-9 rounded-full object-cover"
  />
  <div class="text-foreground-secondary flex flex-col text-sm font-bold">
    <span class="text-foreground">{author}</span>
    <span class="font-mono text-xs">
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
      {readTime && <span>· {readTime} min read</span>}
    </span>
  </div>
</div>
