---
import { tagColor } from '../data/blog';

type Props = {
  tag: string;
  href?: string;
  class?: string;
};

const { tag, href, class: className } = Astro.props;

const baseClasses =
  'themed-border border-border font-heading inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-bold tracking-wider uppercase';
const Element = href ? 'a' : 'span';
---

<Element
  href={href}
  class:list={[
    baseClasses,
    tagColor(tag),
    href && 'hover:brightness-95 transition-all',
    className,
  ]}
>
  {tag}
</Element>
