---
import type { BlogPost } from '../data/blog';
import { readingTime } from '../data/blog';
import Byline from './Byline.astro';
import PostTag from './PostTag.astro';

type Props = {
  post: BlogPost;
};

const { post } = Astro.props;
const { title, description, date, author, tags, cover } = post.data;
const href = `/blog/${post.id}/`;
const readTime = readingTime(post.body);
---

<a
  href={href}
  data-tags={tags.join(',')}
  class="themed-border border-border bg-background-secondary shadow-shadow hover:translate-x-shadow-x hover:translate-y-shadow-y flex flex-col overflow-hidden rounded-md text-left transition-all hover:shadow-none"
>
  <div class="bg-background border-border aspect-video overflow-hidden border-b-2">
    {
      cover && (
        <img
          src={cover}
          alt={title}
          loading="lazy"
          class="h-full w-full object-cover"
        />
      )
    }
  </div>

  <div class="flex flex-1 flex-col gap-3 p-6">
    <div class="flex flex-wrap gap-2">
      {tags.map((tag: string) => <PostTag tag={tag} />)}
    </div>

    <h2 class="font-heading text-xl font-black tracking-wide">
      {title}
    </h2>

    <p class="text-foreground/80 text-sm leading-relaxed">{description}</p>
  </div>

  <div class="bg-background border-border mt-auto border-t-2 p-4">
    <Byline author={author} date={date} readTime={readTime} />
  </div>
</a>
