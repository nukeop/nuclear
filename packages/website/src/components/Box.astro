---
type Props = {
  as?: string;
  class?: string;
  [key: string]: unknown;
};

const { as: Element = 'div', class: className, ...rest } = Astro.props;
---

<Element
  class:list={[
    'themed-border border-border bg-primary rounded-md shadow-shadow relative text-center',
    className,
  ]}
  {...rest}
>
  <slot name="badge" />
  <slot />
</Element>
