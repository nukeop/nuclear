---
type Props = {
  as?: string;
  class?: string;
  [key: string]: unknown;
};

const { as: Element = 'div', class: className, ...rest } = Astro.props;
---

<Element
  class:list={[
    'themed-border border-border bg-primary shadow-shadow relative overflow-visible rounded-md text-center',
    className,
  ]}
  {...rest}
>
  <slot name="badge" />
  <div class="overflow-hidden rounded-[calc(var(--radius,0.375rem)-var(--border-width,2px))]">
    <slot />
  </div>
</Element>
