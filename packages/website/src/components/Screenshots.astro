---
import { Image } from 'astro:assets';

import dashboardAqua from '../../../docs/.gitbook/assets/dashboard-aqua.png';
import dashboardGreen from '../../../docs/.gitbook/assets/dashboard-green.png';
import dashboardMain from '../../../docs/.gitbook/assets/dashboard-main.png';
import dashboardMint from '../../../docs/.gitbook/assets/dashboard-mint.png';
import dashboardOrange from '../../../docs/.gitbook/assets/dashboard-orange.png';
import dashboardRed from '../../../docs/.gitbook/assets/dashboard-red.png';
import dashboardViolet from '../../../docs/.gitbook/assets/dashboard-violet.png';
import installedPlugins from '../../../docs/.gitbook/assets/installed-plugins.png';
import logViewer from '../../../docs/.gitbook/assets/log-viewer.png';
import playlists from '../../../docs/.gitbook/assets/playlists.png';
import pluginStore from '../../../docs/.gitbook/assets/plugin-store.png';
import preferences from '../../../docs/.gitbook/assets/preferences.png';
import searchAlbums from '../../../docs/.gitbook/assets/search-albums.png';
import searchArtists from '../../../docs/.gitbook/assets/search-artists.png';
import whatsNew from '../../../docs/.gitbook/assets/whats-new.png';
import Badge from './Badge.astro';
import Box from './Box.astro';

const themes = [
  { src: dashboardGreen, name: 'Green' },
  { src: dashboardAqua, name: 'Aqua' },
  { src: dashboardMint, name: 'Mint' },
  { src: dashboardOrange, name: 'Orange' },
  { src: dashboardRed, name: 'Red' },
  { src: dashboardViolet, name: 'Violet' },
];

const features = [
  { src: searchArtists, label: 'Search artists' },
  { src: searchAlbums, label: 'Search albums' },
  { src: playlists, label: 'Playlists' },
  { src: pluginStore, label: 'Plugin store' },
  { src: installedPlugins, label: 'Installed plugins' },
  { src: preferences, label: 'Preferences' },
  { src: whatsNew, label: "What's new" },
  { src: logViewer, label: 'Log viewer' },
];
---

<section
  class="px-4 py-16 md:px-8 z-10 relative w-full max-w-5xl mx-auto flex flex-col items-center gap-16"
>
  {/* Section A - Hero screenshot */}
  <div class="w-full rotate-1">
    <Box>
      <Badge slot="badge">Screenshots</Badge>
      <div class="leading-0">
        <Image
          src={dashboardMain}
          alt="Nuclear music player dashboard"
          widths={[960, 1280, 1920, 2972]}
          sizes="(max-width: 640px) 90vw, (max-width: 1024px) 80vw, 960px"
          class="w-full block"
        />
      </div>
    </Box>
  </div>

  {/* Section B - Theme showcase */}
  <div class="w-full">
    <h3
      class="font-heading font-black text-2xl md:text-3xl uppercase tracking-widest text-center mb-8"
    >
      Built-in themes
    </h3>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
      {
        themes.map((theme) => (
          <div class="flex flex-col items-center gap-2">
            <div class="themed-border border-border rounded-md shadow-shadow overflow-hidden bg-primary">
              <Image
                src={theme.src}
                alt={`Nuclear dashboard with ${theme.name} theme`}
                widths={[480, 720, 960]}
                sizes="(max-width: 640px) 45vw, (max-width: 1024px) 30vw, 300px"
                class="w-full block"
              />
            </div>
            <span class="font-heading font-bold text-sm uppercase tracking-wider">
              {theme.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>

  {/* Section C - Feature grid */}
  <div class="w-full">
    <h3
      class="font-heading font-black text-2xl md:text-3xl uppercase tracking-widest text-center mb-8"
    >
      Features
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6 items-start">
      {
        features.map((feature) => (
          <div class="themed-border border-border rounded-md shadow-shadow overflow-hidden bg-primary">
            <div class="leading-0">
              <Image
                src={feature.src}
                alt={feature.label}
                widths={[640, 960, 1280]}
                sizes="(max-width: 640px) 90vw, (max-width: 1024px) 45vw, 480px"
                class="w-full block"
              />
            </div>
            <div class="px-3 py-2 border-t-2 border-border bg-background-secondary">
              <span class="font-heading font-bold text-sm uppercase tracking-wider">
                {feature.label}
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
