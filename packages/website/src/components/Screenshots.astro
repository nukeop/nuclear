---
import { Image } from 'astro:assets';

import dashboardAqua from '../../../docs/.gitbook/assets/dashboard-aqua.png';
import dashboardGreen from '../../../docs/.gitbook/assets/dashboard-green.png';
import dashboardMain from '../../../docs/.gitbook/assets/dashboard-main.png';
import dashboardMint from '../../../docs/.gitbook/assets/dashboard-mint.png';
import dashboardOrange from '../../../docs/.gitbook/assets/dashboard-orange.png';
import dashboardRed from '../../../docs/.gitbook/assets/dashboard-red.png';
import dashboardViolet from '../../../docs/.gitbook/assets/dashboard-violet.png';
import installedPlugins from '../../../docs/.gitbook/assets/installed-plugins.png';
import logViewer from '../../../docs/.gitbook/assets/log-viewer.png';
import playlists from '../../../docs/.gitbook/assets/playlists.png';
import pluginStore from '../../../docs/.gitbook/assets/plugin-store.png';
import preferences from '../../../docs/.gitbook/assets/preferences.png';
import searchAlbums from '../../../docs/.gitbook/assets/search-albums.png';
import searchArtists from '../../../docs/.gitbook/assets/search-artists.png';
import whatsNew from '../../../docs/.gitbook/assets/whats-new.png';
import Badge from './Badge.astro';
import Box from './Box.astro';

const themes = [
  { src: dashboardViolet, name: 'Aurora' },
  { src: dashboardAqua, name: 'Lagoon' },
  { src: dashboardMint, name: 'Arctic Moss' },
  { src: dashboardOrange, name: 'Canyon' },
  { src: dashboardRed, name: 'Molten Core' },
  { src: dashboardGreen, name: 'Midnight Terminal' },
];

const features = [
  { src: searchArtists, label: 'Search artists', rotate: 'rotate-[0.8deg]' },
  { src: searchAlbums, label: 'Search albums', rotate: '-rotate-[0.6deg]' },
  { src: playlists, label: 'Playlists', rotate: '-rotate-1' },
  { src: pluginStore, label: 'Plugin store', rotate: 'rotate-[0.7deg]' },
  {
    src: installedPlugins,
    label: 'Installed plugins',
    rotate: 'rotate-[0.5deg]',
  },
  { src: preferences, label: 'Preferences', rotate: '-rotate-[0.8deg]' },
  { src: whatsNew, label: "What's new", rotate: '-rotate-[0.6deg]' },
  { src: logViewer, label: 'Log viewer', rotate: 'rotate-1' },
];
---

<section
  class="relative z-10 mx-auto flex w-full max-w-5xl flex-col items-center gap-16 px-4 py-16 md:px-8"
>
  {/* Section A - Hero screenshot */}
  <div class="w-full rotate-1">
    <Box>
      <Badge slot="badge">Screenshots</Badge>
      <div class="leading-0">
        <Image
          src={dashboardMain}
          alt="Nuclear music player dashboard"
          widths={[960, 1280, 1920, 2972]}
          sizes="(max-width: 640px) 90vw, (max-width: 1024px) 80vw, 960px"
          class="block w-full"
        />
      </div>
    </Box>
  </div>

  {/* Section B - Theme showcase */}
  <div class="w-full">
    <h3
      class="font-heading mb-8 text-center text-2xl font-black tracking-widest uppercase md:text-3xl"
    >
      Built-in themes
    </h3>
    <div class="themes-cascade">
      {
        themes.map((theme, index) => (
          <div
            class="theme-card themed-border border-border shadow-shadow bg-primary overflow-hidden rounded-md"
            style={`--index: ${index};`}
          >
            <Image
              src={theme.src}
              alt={`Nuclear dashboard with ${theme.name} theme`}
              widths={[480, 720, 960]}
              sizes="(max-width: 640px) 45vw, (max-width: 1024px) 30vw, 300px"
              class="block w-full"
            />
          </div>
        ))
      }
    </div>
  </div>

  {/* Section C - Feature grid */}
  <div class="w-full">
    <h3
      class="font-heading mb-8 text-center text-2xl font-black tracking-widest uppercase md:text-3xl"
    >
      Features
    </h3>
    <div class="grid grid-cols-1 items-start gap-5 md:grid-cols-2 md:gap-6">
      {
        features.map((feature) => (
          <div
            class:list={[
              'themed-border border-border shadow-shadow bg-primary overflow-hidden rounded-md',
              feature.rotate,
            ]}
          >
            <div class="leading-0">
              <Image
                src={feature.src}
                alt={feature.label}
                widths={[640, 960, 1280]}
                sizes="(max-width: 640px) 90vw, (max-width: 1024px) 45vw, 480px"
                class="block w-full"
              />
            </div>
            <div class="border-border bg-background-secondary flex border-t px-3 py-2">
              <span class="font-heading w-full text-center text-sm font-bold tracking-wider uppercase">
                {feature.label}
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .themes-cascade {
    --card-width: 320px;
    --overlap: 200px;
    --rotate-y: 25deg;

    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1400px;
  }

  .theme-card {
    flex-shrink: 0;
    width: var(--card-width);
    margin-right: calc(-1 * var(--overlap));
    transform: rotateY(calc(-1 * var(--rotate-y)));
  }

  .theme-card:last-child {
    margin-right: 0;
  }

  @media (max-width: 768px) {
    .themes-cascade {
      --card-width: 220px;
      --overlap: 140px;
      --rotate-y: 22deg;
      perspective: 1000px;
    }
  }

  @media (max-width: 480px) {
    .themes-cascade {
      --card-width: 160px;
      --overlap: 100px;
      --rotate-y: 20deg;
      perspective: 800px;
    }
  }
</style>
