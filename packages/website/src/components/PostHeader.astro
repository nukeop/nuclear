---
import { Byline } from './Byline';
import { PostTag } from './PostTag';

type Props = {
  title: string;
  author: string;
  date: string;
  readTime: number;
  tags: string[];
};

const { title, author, date, readTime, tags } = Astro.props;
---

<header class="mb-8 flex flex-col gap-4">
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => <PostTag tag={tag} />)}
  </div>
  <h1 class="font-heading text-3xl font-black tracking-wide md:text-4xl">
    {title}
  </h1>
  <Byline author={author} date={date} readTime={readTime} />
</header>
