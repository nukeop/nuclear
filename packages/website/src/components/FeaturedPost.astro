---
import type { BlogPost } from '../data/blog';
import { readingTime } from '../data/blog';
import Byline from './Byline.astro';
import PostTag from './PostTag.astro';

type Props = {
  post: BlogPost;
};

const { post } = Astro.props;
const { title, description, date, author, tags, cover } = post.data;
const href = `/blog/${post.id}/`;
const readTime = readingTime(post.body);
---

<a
  href={href}
  data-tags={tags.join(',')}
  class="themed-border border-border bg-background-secondary shadow-shadow hover:translate-x-shadow-x hover:translate-y-shadow-y grid grid-cols-1 overflow-hidden rounded-md text-left transition-all hover:shadow-none md:grid-cols-2"
>
  <div class="bg-background border-border aspect-video overflow-hidden border-b-2 md:aspect-auto md:border-r-2 md:border-b-0">
    {
      cover && (
        <img
          src={cover}
          alt={title}
          class="h-full w-full object-cover"
        />
      )
    }
  </div>

  <div class="flex flex-col">
    <div class="flex flex-1 flex-col gap-4 p-8">
      <div class="flex flex-wrap gap-2">
        {tags.map((tag: string) => <PostTag tag={tag} />)}
      </div>

      <h2 class="font-heading text-3xl font-black tracking-wide md:text-4xl">
        {title}
      </h2>

      <p class="text-foreground/80 leading-relaxed">{description}</p>
    </div>

    <div class="bg-background border-border border-t-2 px-8 py-4">
      <Byline author={author} date={date} readTime={readTime} />
    </div>
  </div>
</a>
