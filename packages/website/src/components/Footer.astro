---
import { Icon } from 'astro-icon/components';

import Button from './Button.astro';
---

<footer
  class="border-border bg-primary relative overflow-hidden border-t py-12"
>
  <div
    class="mx-auto grid max-w-7xl grid-cols-1 gap-12 px-6 sm:grid-cols-2 lg:grid-cols-4 lg:gap-10"
  >
    <div class="flex flex-col items-start gap-4">
      <a href="/" class="inline-block">
        <img
          src="/images/logo-full-outlined.svg"
          alt="Nuclear"
          class="dark-mode-hidden h-8"
        />
        <img
          src="/images/logo-full-light-outlined.svg"
          alt="Nuclear"
          class="dark-mode-block hidden h-8"
        />
      </a>
      <p class="text-foreground-secondary text-sm font-bold">
        Nuclear is a free, open-source music player without ads or tracking.
        Search for any song or artist, build playlists, and start listening.
      </p>
      <Button
        href="https://github.com/nukeop/nuclear/releases"
        variant="secondary"
        class="font-bold"
        size="sm"
      >
        Download →
      </Button>
    </div>

    <div>
      <h3 class="font-heading text-sm font-bold tracking-widest uppercase">
        Get started
      </h3>
      <ul class="mt-3 flex flex-col gap-2 text-sm">
        <li>
          <a href="https://docs.nuclearplayer.com" class="hover:underline"
            >Documentation</a
          >
        </li>
        <li>
          <a
            href="https://docs.nuclearplayer.com/nuclear/user-manual/getting-started"
            class="hover:underline">Getting started</a
          >
        </li>
        <li>
          <a
            href="https://docs.nuclearplayer.com/nuclear/theming/themes"
            class="hover:underline">Themes</a
          >
        </li>
        <li>
          <a
            href="https://docs.nuclearplayer.com/nuclear/plugins/plugin-store"
            class="hover:underline">Plugin store</a
          >
        </li>
        <li>
          <a
            href="https://github.com/nukeop/nuclear/releases"
            class="hover:underline">Releases</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h3 class="font-heading text-sm font-bold tracking-widest uppercase">
        Resources
      </h3>
      <ul class="mt-3 flex flex-col gap-2 text-sm">
        <li>
          <a
            href="https://docs.nuclearplayer.com/nuclear/user-manual/installation"
            class="hover:underline">Installation</a
          >
        </li>
        <li>
          <a
            href="https://flathub.org/en/apps/com.nuclearplayer.Nuclear"
            class="hover:underline">Flathub</a
          >
        </li>
        <li>
          <a
            href="https://aur.archlinux.org/packages/nuclear-player-bin"
            class="hover:underline">AUR</a
          >
        </li>
        <li>
          <a
            href="https://github.com/nukeop/nuclear/discussions"
            class="hover:underline">Discuss</a
          >
        </li>
      </ul>
    </div>

    <div class="relative">
      <h3 class="font-heading text-sm font-bold tracking-widest uppercase">
        Follow us
      </h3>
      <div class="mt-3 flex gap-3">
        <a href="https://github.com/nukeop/nuclear" aria-label="GitHub"
          ><Icon name="simple-icons:github" class="h-5 w-5" /></a
        >
        <a href="https://fosstodon.org/@nuclearplayer" aria-label="Mastodon"
          ><Icon name="simple-icons:mastodon" class="h-5 w-5" /></a
        >
        <a href="https://twitter.com/nuclear_player" aria-label="Twitter"
          ><Icon name="simple-icons:twitter" class="h-5 w-5" /></a
        >
        <a href="https://discord.gg/JqPjKxE" aria-label="Discord"
          ><Icon name="simple-icons:discord" class="h-5 w-5" /></a
        >
      </div>
    </div>
  </div>

  <img
    src="/images/nuki-listening.png"
    alt="Nuclear mascot Nuki listening to music"
    class="pointer-events-none absolute right-8 -bottom-1 z-10 w-36 select-none lg:right-8 lg:w-48"
  />
</footer>
