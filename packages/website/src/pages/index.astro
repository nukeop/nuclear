---
import Downloads from '../components/Downloads.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

import '../styles/global.css';

const title = 'Nuclear';
const description =
  'Nuclear is a free, open-source music player without ads or tracking. Search for any song or artist, build playlists, and start listening.';
---

<BaseLayout title={title} description={description}>
  <main
    class="relative min-h-screen bg-background flex flex-col items-center justify-center"
  >
    <div
      class="absolute inset-0 bg-grid-pattern opacity-10 pointer-events-none"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute inset-0 bg-radial-fade pointer-events-none"
      aria-hidden="true"
    >
    </div>
    <Hero version="v1.20.0" />
    <Downloads />
  </main>
</BaseLayout>
