---
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

import '../styles/global.css';

const title = 'Nuclear Music Player';
const description =
  'A free, open-source desktop music player that streams from free sources.';
---

<BaseLayout title={title} description={description}>
  <main class="relative min-h-screen bg-white flex items-center justify-center">
    <div
      class="absolute inset-0 bg-grid-pattern opacity-10 pointer-events-none"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse at center, white 0%, transparent 70%);"
      aria-hidden="true"
    >
    </div>
    <Hero version="v1.1.0" />
  </main>
</BaseLayout>
