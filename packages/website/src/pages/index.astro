---
import Features from '../components/Features.astro';
import Hero from '../components/Hero.astro';
import Testimonials from '../components/Testimonials.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

import '../styles/global.css';

const title = 'Nuclear - Free Open-Source Music Player';
const description =
  'Nuclear is a free, open-source music player without ads or tracking. Search for any song or artist, build playlists, and start listening.';
---

<BaseLayout title={title} description={description}>
  <main class="bg-background-secondary relative flex flex-col items-center">
    <div class="relative flex w-full flex-col items-center justify-center">
      <div
        class="bg-grid-pattern pointer-events-none absolute inset-0 opacity-10"
        aria-hidden="true"
      >
      </div>
      <div
        class="bg-radial-fade pointer-events-none absolute inset-0"
        aria-hidden="true"
      >
      </div>
      <Hero />
    </div>
    <section
      class="relative z-10 mx-auto flex w-full max-w-7xl flex-col items-center gap-16 px-4 py-16 md:px-8"
    >
      <Features />
    </section>
    <Testimonials />
  </main>
</BaseLayout>
