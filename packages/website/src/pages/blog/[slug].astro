---
import { render } from 'astro:content';

import PostBody from '../../components/PostBody.astro';
import PostCover from '../../components/PostCover.astro';
import PostHeader from '../../components/PostHeader.astro';
import PostToolbar from '../../components/PostToolbar.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { readingTime } from '../../lib/blog/format';
import {
  getPublishedPosts,
  getRelatedPosts,
  toSummary,
} from '../../lib/blog/queries';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
const { title, description, date, author, tags, cover } = post.data;
const related = getRelatedPosts(post, posts).map(toSummary);
const readTime = readingTime(post.body);
const { Content } = await render(post);

const postUrl = new URL(Astro.url.pathname, Astro.site).href;
const blogUrl = new URL('/blog/', Astro.site).href;
const siteUrl = Astro.site?.toString() ?? 'https://nuclearplayer.com/';
const coverUrl = cover ? new URL(cover, Astro.site).toString() : undefined;

const blogPostingSchema = {
  '@type': 'BlogPosting',
  '@id': `${postUrl}#article`,
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: { '@type': 'Person', name: author },
  publisher: { '@id': `${siteUrl}#organization` },
  mainEntityOfPage: postUrl,
  keywords: tags,
  ...(coverUrl ? { image: coverUrl } : {}),
};

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Blog', item: blogUrl },
    { '@type': 'ListItem', position: 2, name: title, item: postUrl },
  ],
};
---

<BaseLayout
  title={`${title} - Nuclear`}
  description={description}
  ogType="article"
  ogImage={cover}
  article={{
    publishedTime: date.toISOString(),
    author,
    tags,
  }}
  extraSchema={[blogPostingSchema, breadcrumbSchema]}
>
  <main
    class="bg-background-secondary w-full bg-[radial-gradient(var(--background)_1px,transparent_1px)] bg-size-[20px_20px]"
  >
    <div class="mx-auto w-full max-w-3xl px-4 py-16 md:px-8">
      <a
        href="/blog/"
        class="text-primary mb-8 inline-block text-sm font-bold hover:underline"
      >
        ← Back to blog
      </a>

      <article>
        <PostHeader
          title={title}
          author={author}
          date={date.toISOString()}
          readTime={readTime}
          tags={tags}
        />
        {cover && <PostCover src={cover} alt={title} />}
        <PostBody>
          <Content />
        </PostBody>
      </article>

      <PostToolbar url={postUrl} />

      <RelatedPosts posts={related} />
    </div>
  </main>
</BaseLayout>
