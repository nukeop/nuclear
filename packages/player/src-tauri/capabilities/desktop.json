{
  "identifier": "desktop-capability",
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "updater:default",
    "process:default",
    "window-state:default",
    "core:window:allow-set-decorations",
    "core:window:allow-start-dragging"
  ]
}