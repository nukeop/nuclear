          cx="6"
          cy="18"
          r="3"
        />
        <circle
          cx="18"
          cy="16"
          r="3"
        />
      </svg>
    </div>
    <div
      class="truncate px-2"
      data-testid="history-row-artist"
    >
      Radiohead
    </div>
    <div
      class="truncate px-2"
    >
