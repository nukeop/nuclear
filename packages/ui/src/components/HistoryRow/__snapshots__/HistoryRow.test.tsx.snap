        aria-hidden="true"
        class="lucide lucide-music text-foreground opacity-20"
        fill="none"
        height="20"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2.4"
        viewBox="0 0 24 24"
        width="20"
